# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is in .gitignore — never commit the real file.

# ── Firebase (Authentication) ─────────────────────────────────────────────
[firebase]
# Firebase Console → Project Settings → General → Web API Key
api_key = "YOUR_FIREBASE_WEB_API_KEY"

# How to get it:
# 1. https://console.firebase.google.com/ → create / open project
# 2. Project Settings (gear) → General tab → Web API Key
# 3. Authentication → Sign-in method → enable Email/Password + Phone
# 4. Authentication → Settings → Authorised domains → add your Streamlit URL


# ── Gmail SMTP (Email Alerts) ─────────────────────────────────────────────
[smtp]
host     = "smtp.gmail.com"
port     = 587
user     = "nifty50alerts@gmail.com"         # your dedicated app Gmail
password = "xxxx xxxx xxxx xxxx"              # 16-char Gmail App Password
from     = "Nifty50 Tracker <nifty50alerts@gmail.com>"

# How to create a Gmail App Password (2 mins):
# 1. Create a dedicated Gmail e.g. nifty50alerts@gmail.com
# 2. Enable 2-Step Verification on that account
# 3. myaccount.google.com/apppasswords → generate → copy 16 chars
# 4. Paste the 16 chars (no spaces) as the password above


# ── Twilio (SMS Alerts) ───────────────────────────────────────────────────
[twilio]
sid   = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Account SID
token = "your_auth_token"                     # Auth Token
from  = "+1415XXXXXXX"                        # Your Twilio phone number

# How to get Twilio credentials (3 mins):
# 1. Sign up at https://twilio.com/try-twilio  (free trial)
# 2. Console dashboard → Account SID + Auth Token
# 3. Phone Numbers → get a free number → paste above
# Free trial: SMS to verified numbers only
# Pay-as-you-go: ~Rs.0.65/SMS to any Indian number
#
# For Streamlit Cloud: paste all three sections into
# App Settings → Secrets (the TOML editor there).
