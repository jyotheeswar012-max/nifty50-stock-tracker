# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is already in .gitignore — never commit it.

[firebase]
# Get this from Firebase Console → Project Settings → General → Web API Key
api_key = "YOUR_FIREBASE_WEB_API_KEY"

# ── How to get your Firebase Web API Key ──────────────────────────
# 1. Go to https://console.firebase.google.com/
# 2. Create a project (or use an existing one)
# 3. Project Settings (gear icon) → General tab
# 4. Under "Your apps", copy the "Web API Key"
# 5. In Firebase Console → Authentication → Sign-in method:
#    - Enable "Email/Password"
#    - Enable "Phone" (optional, requires reCAPTCHA — see README)
# 6. Paste the API key above and save this file as secrets.toml
