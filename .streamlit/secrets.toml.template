# ==========================================================================
# .streamlit/secrets.toml  —  TEMPLATE  (safe to commit)
# ==========================================================================
# Copy this file to  .streamlit/secrets.toml  and fill in real values.
# The real secrets.toml is git-ignored and must NEVER be committed.
#
# On Streamlit Community Cloud: paste each section under
#   App settings → Secrets  (TOML format).
# On a self-hosted server: set the same keys as environment variables
#   prefixed with STREAMLIT__  e.g. STREAMLIT__FIREBASE__API_KEY=...
# ==========================================================================

# --------------------------------------------------------------------------
# Firebase Web API key  (required for email/phone auth)
# --------------------------------------------------------------------------
# How to find it:
#   Firebase Console → Project Settings → General → Web API Key
[firebase]
api_key = "AIzaSy__REPLACE_WITH_YOUR_FIREBASE_WEB_API_KEY"

# --------------------------------------------------------------------------
# SMTP  (optional — enables email price-alert notifications)
# --------------------------------------------------------------------------
# Any SMTP relay works: Gmail (with App Password), SendGrid, Mailgun, etc.
# Gmail App Password guide: https://support.google.com/accounts/answer/185833
[smtp]
host     = "smtp.gmail.com"
port     = 587
user     = "your-sender@gmail.com"
password = "your-16-char-app-password"   # NOT your Gmail login password
from     = "NSE Tracker <your-sender@gmail.com>"

# --------------------------------------------------------------------------
# Twilio  (optional — enables SMS price-alert notifications)
# --------------------------------------------------------------------------
[twilio]
sid   = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
token = "your-auth-token"
from  = "+1XXXXXXXXXX"   # Twilio phone number in E.164 format

# --------------------------------------------------------------------------
# Supabase  (optional — alternative/additional auth backend)
# --------------------------------------------------------------------------
[supabase]
url     = "https://xxxxxxxxxxx.supabase.co"
key     = "eyJ...your-anon-public-key"
service = "eyJ...your-service-role-key-DO-NOT-EXPOSE-CLIENT-SIDE"
